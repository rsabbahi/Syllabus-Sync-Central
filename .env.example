# ── Existing Node.js Configuration ────────────────────────────────────────

# OpenAI API (optional - for other features)
OPENAI_API_KEY=your_openai_api_key_here
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Replit/Auth configuration
# (Set these if using authentication)
AUTH_ENABLED=false

# ── Python Backend Configuration ───────────────────────────────────────────

# Python FastAPI Backend URL (for LLM syllabus parsing)
PYTHON_BACKEND_URL=http://localhost:8000

# Ollama Configuration (used by Python backend)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120

# Python Backend Logging
LOG_LEVEL=INFO

# ── Port Configuration ─────────────────────────────────────────────────────

PORT=3000
PYTHON_PORT=8000
OLLAMA_PORT=11434
